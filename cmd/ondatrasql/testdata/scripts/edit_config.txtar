# edit with special targets finds config files
# EDITOR=true just exits 0 without opening anything
exec ondatrasql init
env EDITOR=true

# Edit special config targets
exec ondatrasql edit catalog
exec ondatrasql edit settings
exec ondatrasql edit variables/constants
exec ondatrasql edit macros/helpers
exec ondatrasql edit sources
exec ondatrasql edit secrets
exec ondatrasql edit extensions
