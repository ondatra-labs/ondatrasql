# Bug S5 (v0.12.1 fix): a sandbox run on a model with audits/constraints/
# warnings must always evaluate them, even if the SQL hash is unchanged.
# Pre-fix the runner saw prev_hash == current_hash and short-circuited to
# skip, leaving "Audits: N not evaluated (model skipped)" — which let users
# deploy edited audit thresholds without ever running the new threshold.
# Post-fix the runner forces a backfill in sandbox when directives are
# present, so audits always pass or fail visibly.

exec ondatrasql init
mkdir models/raw
cp m.sql models/raw/audited.sql

# First run prod so the model exists in the catalog (sandbox compares vs prod).
exec ondatrasql run raw.audited

# Sandbox the same model unchanged → audits MUST run (S5 fix).
exec ondatrasql sandbox raw.audited
stdout 'Audits: 1 passed'
! stdout 'not evaluated'

-- m.sql --
-- @kind: table
-- @audit: row_count >= 1
SELECT 1 AS x
